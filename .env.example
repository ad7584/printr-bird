# Vite inlines any VITE_* var at build time.

# Privy app ID (public — safe in browser bundle).
# Grab from https://dashboard.privy.io → your app → Settings.
VITE_PRIVY_APP_ID=

# Backend base URL. Defaults to localhost:3000 in dev.
VITE_BACKEND_URL=http://localhost:3000

# Solana RPC used client-side for building + simulating txs.
# Use Helius / QuickNode in prod; public mainnet is fine for dev.
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
VITE_SOLANA_CLUSTER=mainnet-beta

# $BIRD mint address (same value as the backend's BIRD_MINT).
VITE_BIRD_MINT=

# ----- 3-wallet treasury destinations (must match backend) -----
# Ops multisig (Squads vault) — receives 20% of every SOL payment.
VITE_OPS_MULTISIG=
# Buyback wallet (Privy server wallet) — receives 50% of every SOL payment.
VITE_BUYBACK_WALLET=
# Prize wallet (Privy server wallet) — receives 30% of every SOL payment.
VITE_PRIZE_WALLET=

# Split in basis points — must match backend SPLIT_*_BPS and sum to 10000.
VITE_SPLIT_OPS_BPS=2000
VITE_SPLIT_BUYBACK_BPS=5000
VITE_SPLIT_PRIZE_BPS=3000

# Incinerator (burn) address — $BIRD gets burned here via SPL Burn instruction.
VITE_BURN_ADDRESS=1nc1nerator11111111111111111111111111111111
